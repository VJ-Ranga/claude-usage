#!/usr/bin/env python3
"""Claude Code live usage dashboard using rich."""

import json
import os
import sys
import time
from datetime import datetime, timezone

from rich.console import Console
from rich.layout import Layout
from rich.live import Live
from rich.panel import Panel
from rich.table import Table
from rich.text import Text

STATS_FILE   = os.path.expanduser("~/.claude/stats-cache.json")
LIMITS_FILE  = os.path.expanduser("~/.claude/usage-limits.json")
FETCHER      = os.path.expanduser("~/.local/bin/claude-fetch-limits")
import subprocess

console = Console()

def fmt_tokens(n):
    if n >= 1_000_000: return f"{n/1_000_000:.2f}M"
    if n >= 1_000:     return f"{n/1_000:.1f}K"
    return str(n)

def load_data():
    try:
        with open(STATS_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return None

def load_limits():
    try:
        return json.load(open(LIMITS_FILE))
    except Exception:
        return None

def fetch_limits_bg():
    try:
        subprocess.Popen([sys.executable, FETCHER],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

def fmt_reset(ts):
    if not ts:
        return "?"
    secs = ts - time.time()
    if secs <= 0:
        return "now"
    h = int(secs // 3600)
    m = int((secs % 3600) // 60)
    if h >= 24:
        d = h // 24
        return f"{d}d {h%24}h"
    return f"{h}h {m:02d}m" if h else f"{m}m"

def limit_bar(used, total, width=24):
    p      = min(used / total, 1.0) if total else 0
    filled = round(p * width)
    pct    = int(p * 100)
    color  = "red" if pct >= 85 else "yellow" if pct >= 60 else "green"
    bar    = f"[{color}]" + "█" * filled + f"[/][dim]" + "░" * (width - filled) + "[/]"
    return Text.from_markup(f"  {bar} [bold]{pct}%[/]  {used}/{total} msgs")

def make_limits_panel(limits):
    if limits:
        pct5h = int(limits["5h"]["utilization"] * 100)
        pct7d = int(limits["7d"]["utilization"] * 100)
        r5h   = fmt_reset(limits["5h"]["reset"])
        r7d   = fmt_reset(limits["7d"]["reset"])
        age   = int(time.time() - limits.get("fetchedAt", 0))
        note  = f"[dim]Real data from Anthropic API · fetched {age}s ago[/]"
    else:
        pct5h = pct7d = 0
        r5h = r7d = "?"
        note = "[dim yellow]Fetching real data...[/]"

    content = Text.assemble(("5-Hour Window\n", "bold white"))
    content.append_text(limit_bar(pct5h, 100))
    content.append(f"\n  Resets in: ", "dim")
    content.append(r5h, "bold yellow")
    content.append("\n\n")
    content.append("7-Day Window\n", "bold white")
    content.append_text(limit_bar(pct7d, 100))
    content.append(f"\n  Resets in: ", "dim")
    content.append(r7d, "bold yellow")
    content.append(f"\n\n")
    content.append_text(Text.from_markup(note))
    return Panel(content, title="[bold red]Usage Limits (Real)[/bold red]", border_style="red")

def make_activity_table(data):
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    daily = data.get("dailyActivity", [])[-7:]
    table = Table(title="Daily Activity (last 7 days)", border_style="bright_blue", expand=True)
    table.add_column("Date",       style="cyan",    no_wrap=True)
    table.add_column("Messages",   justify="right", style="green")
    table.add_column("Sessions",   justify="right", style="yellow")
    table.add_column("Tool Calls", justify="right", style="magenta")
    for day in reversed(daily):
        is_today = day["date"] == today
        style    = "bold white on dark_blue" if is_today else ""
        label    = f"[bold]{day['date']} ◀ today[/bold]" if is_today else day["date"]
        table.add_row(label,
            str(day["messageCount"]),
            str(day["sessionCount"]),
            str(day["toolCallCount"]),
            style=style,
        )
    return table

def make_token_panel(data):
    model_usage = data.get("modelUsage", {})
    if not model_usage:
        return Panel("No token data yet.", title="Token Usage")
    rows = []
    for model, stats in model_usage.items():
        short   = model.replace("claude-", "").replace("-latest", "")
        inp     = stats.get("inputTokens", 0)
        out     = stats.get("outputTokens", 0)
        cache_r = stats.get("cacheReadInputTokens", 0)
        cache_w = stats.get("cacheCreationInputTokens", 0)
        cost    = stats.get("costUSD", 0)
        total_in = inp + cache_r + cache_w
        hit_pct  = int(cache_r / total_in * 100) if total_in else 0
        bar_f    = hit_pct // 5
        bar      = "[green]" + "█" * bar_f + "[dim]" + "░" * (20 - bar_f) + "[/]"
        rows.append(Text.assemble(
            ("Model : ", "dim"), (short, "bold cyan"), "\n",
            ("  Input      : ", "dim"), (fmt_tokens(inp),     "green"),    "\n",
            ("  Output     : ", "dim"), (fmt_tokens(out),     "yellow"),   "\n",
            ("  Cache read : ", "dim"), (fmt_tokens(cache_r), "magenta"),  "\n",
            ("  Cache write: ", "dim"), (fmt_tokens(cache_w), "blue"),     "\n",
        ))
        rows.append(Text.from_markup(f"  Cache hit  : {bar} {hit_pct}%"))
        if cost:
            rows.append(Text.assemble(("  Cost: ", "dim"), (f"${cost:.4f}", "bold red")))
    content = Text("\n").join(rows)
    return Panel(content, title="[bold]Token Usage[/bold]", border_style="green")

def make_totals_panel(data):
    longest      = data.get("longestSession", {})
    longest_mins = longest.get("duration", 0) // 60000
    longest_msgs = longest.get("messageCount", 0)
    first        = data.get("firstSessionDate", "")[:10]
    last_updated = data.get("lastComputedDate", "unknown")
    content = Text.assemble(
        ("Total Sessions : ", "dim"), (str(data.get("totalSessions", 0)), "bold cyan"), "\n",
        ("Total Messages : ", "dim"), (str(data.get("totalMessages",  0)), "bold cyan"), "\n",
        ("Longest Session: ", "dim"), (f"{longest_mins} min, {longest_msgs} msgs", "yellow"), "\n",
        ("Using since    : ", "dim"), (first,        "green"),   "\n",
        ("\nFile updated   : ", "dim"), (last_updated, "magenta"),
    )
    return Panel(content, title="[bold]Totals[/bold]", border_style="yellow")

def make_header(interval, remaining):
    now = datetime.now().strftime("%Y-%m-%d  %H:%M:%S")
    return Panel(
        Text.from_markup(
            f"[bold cyan]Claude Code Usage Dashboard[/bold cyan]"
            f"   [dim]{now}[/dim]"
            f"   [yellow]Next refresh in {remaining:2}s[/yellow]"
            f"   [dim]Ctrl+C to stop[/dim]"
        ),
        border_style="bright_blue",
    )

def build_layout(data, limits, interval, remaining):
    layout = Layout()
    layout.split_column(
        Layout(make_header(interval, remaining), size=3),
        Layout(name="body"),
    )
    layout["body"].split_row(
        Layout(name="left"),
        Layout(name="right"),
    )
    layout["left"].split_column(
        Layout(make_limits_panel(limits), size=15),
        Layout(make_activity_table(data)),
    )
    layout["right"].split_column(
        Layout(make_token_panel(data)),
        Layout(make_totals_panel(data)),
    )
    return layout

def main():
    args = sys.argv[1:]
    try:
        interval = int(args[0]) if args else 30
    except ValueError:
        interval = 30

    data = load_data()
    if not data:
        console.print("[red]No Claude stats found.[/red]  Run Claude Code first.")
        sys.exit(1)

    limits = load_limits()
    fetch_limits_bg()

    try:
        with Live(
            build_layout(data, limits, interval, interval),
            refresh_per_second=1,
            screen=True,
        ) as live:
            elapsed = 0
            while True:
                remaining = interval - (elapsed % interval)
                if elapsed % interval == 0 and elapsed > 0:
                    data   = load_data() or data
                    limits = load_limits()
                    fetch_limits_bg()
                live.update(build_layout(data, limits, interval, remaining))
                time.sleep(1)
                elapsed += 1
    except KeyboardInterrupt:
        console.print("\n[dim]Dashboard stopped.[/dim]")

if __name__ == "__main__":
    main()
