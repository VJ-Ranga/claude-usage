#!/usr/bin/env python3
"""
Claude Code MCP server — exposes usage tools to Claude itself.
Pure stdlib, no pip required. Communicates via stdin/stdout JSON-RPC.
"""

import json
import os
import subprocess
import sys
import time
from datetime import datetime, timezone, timedelta

STATS_FILE  = os.path.expanduser("~/.claude/stats-cache.json")
HISTORY_FILE = os.path.expanduser("~/.claude/history.jsonl")
DASHBOARD   = os.path.expanduser("~/.local/bin/claude-dashboard")

# Approximate Claude Code Pro limits — user can override via env
LIMIT_5H  = int(os.environ.get("CLAUDE_LIMIT_5H",  "45"))
LIMIT_5DAY = int(os.environ.get("CLAUDE_LIMIT_5DAY", "225"))

# ── helpers ──────────────────────────────────────────────────────────────────

def fmt_tokens(n):
    if n >= 1_000_000: return f"{n/1_000_000:.2f}M"
    if n >= 1_000:     return f"{n/1_000:.1f}K"
    return str(n)

def pct_bar(used, total, width=20):
    p = min(used / total, 1.0) if total else 0
    filled = round(p * width)
    bar = "█" * filled + "░" * (width - filled)
    return f"[{bar}] {int(p*100)}%  ({used}/{total})"

def load_stats():
    try:
        with open(STATS_FILE) as f:
            return json.load(f)
    except Exception:
        return {}

def count_history_window(hours=None, days=None):
    """Count messages from history.jsonl within a time window."""
    now_ms = time.time() * 1000
    if hours:
        cutoff = now_ms - hours * 3600 * 1000
    else:
        cutoff = now_ms - days * 86400 * 1000
    count = 0
    try:
        with open(HISTORY_FILE) as f:
            for line in f:
                obj = json.loads(line)
                ts = obj.get("timestamp", 0)
                if isinstance(ts, (int, float)) and ts >= cutoff:
                    count += 1
    except Exception:
        pass
    return count

# ── tools ────────────────────────────────────────────────────────────────────

TOOLS = [
    {
        "name": "get_usage",
        "description": "Show Claude Code usage summary including daily activity, token counts, and progress toward 5-hour and 5-day limits.",
        "inputSchema": {
            "type": "object",
            "properties": {},
            "required": []
        }
    },
    {
        "name": "launch_dashboard",
        "description": "Open the Claude usage live dashboard in a new terminal window.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "interval": {
                    "type": "integer",
                    "description": "Refresh interval in seconds (default 30)",
                    "default": 30
                }
            },
            "required": []
        }
    }
]

def tool_get_usage():
    data   = load_stats()
    msgs5h  = count_history_window(hours=5)
    msgs5d  = count_history_window(days=5)

    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    last  = data.get("lastComputedDate", "unknown")

    lines = []
    lines.append("━━━ Claude Code Usage ━━━")
    lines.append("")

    # 5h / 5-day limits
    lines.append("📊 Usage Limits")
    lines.append(f"  5-hour  : {pct_bar(msgs5h,  LIMIT_5H)}")
    lines.append(f"  5-day   : {pct_bar(msgs5d, LIMIT_5DAY)}")
    lines.append(f"  (limits: {LIMIT_5H} msgs/5h · {LIMIT_5DAY} msgs/5day — set CLAUDE_LIMIT_5H / CLAUDE_LIMIT_5DAY to override)")
    lines.append("")

    # Daily activity
    daily = data.get("dailyActivity", [])
    if daily:
        lines.append("📅 Recent Daily Activity")
        for day in reversed(daily[-5:]):
            mark = " ◀ today" if day["date"] == today else ""
            lines.append(f"  {day['date']}  msgs={day['messageCount']:3}  sessions={day['sessionCount']}  tools={day['toolCallCount']}{mark}")
        lines.append("")

    # Tokens
    model_usage = data.get("modelUsage", {})
    if model_usage:
        lines.append("🔢 Token Usage (all time)")
        for model, s in model_usage.items():
            short = model.replace("claude-", "").replace("-latest", "")
            inp     = fmt_tokens(s.get("inputTokens", 0))
            out     = fmt_tokens(s.get("outputTokens", 0))
            cache_r = fmt_tokens(s.get("cacheReadInputTokens", 0))
            cache_w = fmt_tokens(s.get("cacheCreationInputTokens", 0))
            total_in = s.get("inputTokens", 0) + s.get("cacheReadInputTokens", 0) + s.get("cacheCreationInputTokens", 0)
            hit_pct  = int(s.get("cacheReadInputTokens", 0) / total_in * 100) if total_in else 0
            lines.append(f"  {short}: in={inp}  out={out}  cache_read={cache_r}  cache_write={cache_w}  hit={hit_pct}%")
        lines.append("")

    # Totals
    lines.append(f"📈 Totals: {data.get('totalSessions',0)} sessions · {data.get('totalMessages',0)} messages")
    longest = data.get("longestSession", {})
    if longest:
        mins = longest.get("duration", 0) // 60000
        lines.append(f"   Longest session: {mins} min · {longest.get('messageCount',0)} messages")
    first = data.get("firstSessionDate", "")
    if first:
        lines.append(f"   Using since: {first[:10]}")
    lines.append(f"   Stats file updated: {last}")
    lines.append("")
    lines.append("💡 Run `claude-dashboard` in another terminal for a live view.")

    return "\n".join(lines)

def tool_launch_dashboard(interval=30):
    try:
        terminals = ["gnome-terminal", "xterm", "konsole", "xfce4-terminal", "lxterminal"]
        launched = False
        for term in terminals:
            try:
                if term == "gnome-terminal":
                    subprocess.Popen([term, "--", "bash", "-c",
                        f"{DASHBOARD} {interval}; read -p 'Press enter to close'"])
                else:
                    subprocess.Popen([term, "-e",
                        f"bash -c '{DASHBOARD} {interval}; read -p \"Press enter\"'"])
                launched = True
                break
            except FileNotFoundError:
                continue

        if not launched:
            return f"Could not find a terminal emulator. Run manually: claude-dashboard {interval}"
        return f"Dashboard launched (refresh every {interval}s). Check your new terminal window."
    except Exception as e:
        return f"Error: {e}\nRun manually: claude-dashboard {interval}"

# ── MCP JSON-RPC handler ──────────────────────────────────────────────────────

def send(obj):
    msg = json.dumps(obj)
    sys.stdout.write(msg + "\n")
    sys.stdout.flush()

def handle(req):
    method = req.get("method", "")
    rid    = req.get("id")

    if method == "initialize":
        send({"jsonrpc": "2.0", "id": rid, "result": {
            "protocolVersion": "2024-11-05",
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "claude-usage", "version": "1.0.0"}
        }})

    elif method == "notifications/initialized":
        pass  # no response needed

    elif method == "tools/list":
        send({"jsonrpc": "2.0", "id": rid, "result": {"tools": TOOLS}})

    elif method == "tools/call":
        params = req.get("params", {})
        name   = params.get("name")
        args   = params.get("arguments", {})
        try:
            if name == "get_usage":
                text = tool_get_usage()
            elif name == "launch_dashboard":
                text = tool_launch_dashboard(args.get("interval", 30))
            else:
                text = f"Unknown tool: {name}"
            send({"jsonrpc": "2.0", "id": rid, "result": {
                "content": [{"type": "text", "text": text}]
            }})
        except Exception as e:
            send({"jsonrpc": "2.0", "id": rid, "result": {
                "content": [{"type": "text", "text": f"Error: {e}"}],
                "isError": True
            }})

    elif rid is not None:
        send({"jsonrpc": "2.0", "id": rid, "error": {
            "code": -32601, "message": f"Method not found: {method}"
        }})

def main():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            req = json.loads(line)
            handle(req)
        except json.JSONDecodeError:
            pass

if __name__ == "__main__":
    main()
