#!/usr/bin/env python3
"""
One-line status bar for Claude Code.
Refresh behaviour is controlled by ~/.claude/usage-config.json:
  refresh_mode: "manual"        — never auto-refresh (default, safest)
  refresh_mode: "auto"          — refresh every refresh_interval_min minutes
  refresh_interval_min: 30      — interval used when mode is "auto"
"""

import json, os, subprocess, sys, time

LIMITS_FILE  = os.path.expanduser("~/.claude/usage-limits.json")
STATS_FILE   = os.path.expanduser("~/.claude/stats-cache.json")
HISTORY_FILE = os.path.expanduser("~/.claude/history.jsonl")
CONFIG_FILE  = os.path.expanduser("~/.claude/usage-config.json")
FETCHER      = os.path.expanduser("~/.local/bin/claude-fetch-limits")

DEFAULT_CONFIG = {"refresh_mode": "manual", "refresh_interval_min": 30}

def load_config():
    try:
        return {**DEFAULT_CONFIG, **json.load(open(CONFIG_FILE))}
    except Exception:
        return DEFAULT_CONFIG

# Trigger background API refresh if mode is auto and cache is stale
cfg = load_config()
if cfg.get("refresh_mode") == "auto" and os.path.exists(FETCHER):
    try:
        age = time.time() - os.path.getmtime(LIMITS_FILE)
        if age > cfg.get("refresh_interval_min", 30) * 60:
            subprocess.Popen([sys.executable, FETCHER],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

def bar(pct, width=10):
    filled = round(min(pct, 100) / 100 * width)
    return "█" * filled + "░" * (width - filled)

def fmt_reset(ts):
    if not ts:
        return "?"
    secs = ts - time.time()
    if secs <= 0:
        return "now"
    h = int(secs // 3600)
    m = int((secs % 3600) // 60)
    if h >= 24:
        d = h // 24
        return f"{d}d{h%24}h"
    return f"{h}h{m:02d}m" if h else f"{m}m"

def count_msgs(hours):
    now_ms = time.time() * 1000
    cutoff = now_ms - hours * 3600 * 1000
    n = 0
    try:
        with open(HISTORY_FILE) as f:
            for line in f:
                ts = json.loads(line).get("timestamp", 0)
                if isinstance(ts, (int, float)) and ts >= cutoff:
                    n += 1
    except Exception:
        pass
    return n

def estimate(window_key, hours, limits):
    """Return (pct, used, capacity, is_estimated)."""
    util = limits[window_key]["utilization"]
    pct_api = util * 100
    msgs_now = count_msgs(hours)

    # Derive capacity: stored calibration if available, else compute from util + local count
    cal = limits[window_key].get("msgsPerPct")
    if cal:
        capacity = int(cal * 100)
    elif util > 0.001 and msgs_now > 0:
        capacity = int(msgs_now / util)
    else:
        return int(pct_api), None, None, False

    pct = min(msgs_now / (capacity / 100), 100)
    return int(pct), msgs_now, capacity, True

# Read limits and estimate
try:
    limits   = json.load(open(LIMITS_FILE))
    pct5h, used5h, cap5h, est5h = estimate("5h", 5,     limits)
    pct7d, used7d, cap7d, est7d = estimate("7d", 24*7,  limits)
    rst5h = fmt_reset(limits["5h"]["reset"])
    rst7d = fmt_reset(limits["7d"]["reset"])
    tag = "~"
    cnt5h = f"{pct5h}%({used5h}/{cap5h})" if cap5h else f"{pct5h}%"
    cnt7d = f"{pct7d}%({used7d}/{cap7d})" if cap7d else f"{pct7d}%"
except Exception:
    pct5h = pct7d = 0
    rst5h = rst7d = "?"
    cnt5h = cnt7d = "?"
    tag = ""

try:
    total = json.load(open(STATS_FILE)).get("totalMessages", 0)
except Exception:
    total = 0

print(f"5h:{tag}{cnt5h} [{bar(pct5h)}] rst:{rst5h} | 7d:{tag}{cnt7d} [{bar(pct7d)}] rst:{rst7d} | msgs:{total}")
