#!/usr/bin/env python3
"""One-line status bar for Claude Code — uses real API rate limit data."""

import json, os, subprocess, sys, time

LIMITS_FILE = os.path.expanduser("~/.claude/usage-limits.json")
FETCHER     = os.path.expanduser("~/.local/bin/claude-fetch-limits")
STATS_FILE  = os.path.expanduser("~/.claude/stats-cache.json")
CACHE_TTL   = 60  # seconds before background refresh

def bar(pct, width=10):
    filled = round(pct / 100 * width)
    return "█" * filled + "░" * (width - filled)

def fmt_reset(ts):
    if not ts:
        return "?"
    secs = ts - time.time()
    if secs <= 0:
        return "now"
    h = int(secs // 3600)
    m = int((secs % 3600) // 60)
    if h >= 24:
        d = h // 24
        return f"{d}d{h%24}h"
    return f"{h}h{m:02d}m" if h else f"{m}m"

# Background-refresh if cache is stale
try:
    age = time.time() - os.path.getmtime(LIMITS_FILE)
    if age > CACHE_TTL:
        subprocess.Popen([sys.executable, FETCHER],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
except Exception:
    try:
        subprocess.Popen([sys.executable, FETCHER],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

# Read limits cache
try:
    limits = json.load(open(LIMITS_FILE))
    pct5h  = int(limits["5h"]["utilization"] * 100)
    rst5h  = fmt_reset(limits["5h"]["reset"])
    pct7d  = int(limits["7d"]["utilization"] * 100)
    rst7d  = fmt_reset(limits["7d"]["reset"])
except Exception:
    pct5h = pct7d = 0
    rst5h = rst7d = "?"

# Total messages
try:
    total = json.load(open(STATS_FILE)).get("totalMessages", 0)
except Exception:
    total = 0

print(f"5h: {pct5h}% [{bar(pct5h)}] rst:{rst5h} | 7d: {pct7d}% [{bar(pct7d)}] rst:{rst7d} | msgs:{total}")
